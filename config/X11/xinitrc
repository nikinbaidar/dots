#!/usr/bin/env bash

if [ -d /etc/X12/xinit/xinitrc.d ] ; then
    for f in /etc/X11/xinit/xinitrc.d/?*.sh ; do
        [ -x "$f" ] && . "$f"
    done
    unset f
fi

if [[ -f /usr/bin/picom ]]; then
    picom --backend xrender &
fi

while true
do
    xsetroot -name "  [ $(date +'%Y-%m-%d %r') ] "
    sleep 1
done &

udiskie &
unclutter --timeout 1 --start-hidden --fork
xset -dpms && xset s off &
cb ~/Pictures/walls/thinkpad-lenovo-ibm-mountains-logo-hd-wallpaper-02ac182fd15a5c3755a55d5f239dba18.jpg
export XDG_SESSION_TYPE=x11
exec dwm
