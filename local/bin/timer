#!/usr/bin/env bash

minutes=0
seconds=0

while [ -n "${1}" ] ; do
    case "${1}" in 
        -m) minutes="${2}" ;;
        -s) seconds="${2}" ;;
    esac
    shift
done

duration=$(( $(( $minutes * 60)) + ${seconds} ))

function display_remaining() {
    duration=$1
    audio_file="/home/nikin/Music/Cyberpunk 2077 Incoming Call HQ Ringtone-cerCH5Kt8Ng.mp3"
    tput civis

    while [ $duration -ge 0 ]; do
        # Calculate minutes, and seconds
        M=$(( (duration % 3600) / 60 ))
        S=$((duration % 60))
        # Format things to look a bit more nicer.
        M=$(printf "%02d" "$((M % 60))")
        S=$(printf "%02d" "$((S % 60))")
        # Display countdown
        echo -en "  ${M}:${S}\r"
        sleep 1
        duration=$((duration - 1))
    done

    # Timer done now play audio
    mpv --no-video --loop=inf "$audio_file" &
    mpv_pid=$!
    
    # Make sure the audio length is atleast equal out the timeout below 
    sleep 30
    kill -TERM $mpv_pid 2>/dev/null
}

export -f display_remaining 

st -c "Display" -T "Timer" -z 22 \
    -g 9x1 bash -c "display_remaining '$duration'" &
