#!/usr/bin/env bash

set -- $(getopt -o b:m:siprhw -l begin:,mode:,stop,pause,resume,info,help,watch -- "$@")

display_help() {
  cat << 'EOF'
'sc' - Screencast with ffmpeg.

Usage:
  sc [OPTIONS]

Options:
  -b, --begin <file> Start the screencast. <file> must be a video format.
                     If an extension is not provided '.mkv' will be used.

  -h, --help Display this help.

  -i, --info Display info about current recording.

  -m, --mode <mode> Set recording mode with '--begin', and '--resume'.
                      * '0' Record screen and sink (default).
                      * '1' Record screen, sink and source.
                      * '2' Record screen, and source.

  -p, --pause Pause an ongoing recording.

  -r, --resume Resume a paused recording.

  -s, --stop Kill all ffmpeg processes.

  -w, --watch Watch a screencast.
EOF
}


watch_recording() {
    selection=$(fd -I -t f . "$SCREENCAST_DIR" -x basename | fzf) || exit 1
    mpv "${SCREENCAST_DIR}/${selection}" &
}


start_recording () {
    if [ -z "${filename}" ]
    then
        echo "Filename not specified. Aborting..."
        exit 1
    fi

    if [[ "$(basename -- "$filename")" != *.* ]]
    then
        filename="${filename}.mkv"
    fi

    output="${SCREENCAST_DIR}/${filename}"

    if [ -f "${output}" ]
    then
        read -r -p "'${output}' is an existing file. Do you want to overwrite it? [y/N]? " answer
        case "${answer}" in
            [yY]) ;;
            *) exit 1;;
        esac
    fi

    read W H X Y <<< $(xrandr | awk '/ primary / { split($4,a,"[+x]"); print a[1], a[2], a[3], a[4] }')

    sink="$(pactl info | grep 'Default Sink' | awk '{print $3}').monitor"
    source="$(pactl info | grep 'Default Source' | awk '{print $3}')"

    if [ -d "${metadata}" ]
    then
        msg="Recording resumed"
    else
        mkdir -p "${metadata}"
        msg="Recording started"
    fi

    echo title=${filename} > ${metadata}/info
    echo resolution=${W}x${H} >> ${metadata}/info
    echo filepath=${output} >> ${metadata}/info

    if [[ "$mode" == '1' ]]; then
        echo source=${source} >> ${metadata}/info
        echo sink=${sink} >> ${metadata}/info
        ffmpeg -y \
            -f x11grab \
            -r 30 \
            -s ${W}x${H} \
            -i :0.0+${X},${Y} \
            -f pulse \
            -i "${source}" \
            -f pulse \
            -i "${sink}" \
            -filter_complex "[1:a][2:a]amerge=inputs=2[a]" \
            -map 0:v \
            -map "[a]" \
            -c:v libx264  \
            -preset ultrafast \
            -pix_fmt yuv420p \
            -c:a aac \
            -strict experimental \
            "${output}" \
            -hide_banner \
            -loglevel error &
    elif [[ "$mode" == 2 ]]; then
        echo source=${source} >> ${metadata}/info
        ffmpeg -y \
            -f x11grab \
            -r 30 \
            -s ${W}x${H} \
            -i :0.0+${X},${Y} \
            -f pulse \
            -i "${source}" \
            -map 0:v \
            -map 1:a \
            -c:v libx264 \
            -preset ultrafast \
            -pix_fmt yuv420p \
            -c:a aac \
            "${output}" \
            -hide_banner \
            -loglevel error &
    else
        echo sink=${sink} >> ${metadata}/info
        ffmpeg -y \
            -f x11grab \
            -r 30 \
            -s ${W}x${H} \
            -i :0.0+${X},${Y} \
            -f pulse -i "${sink}" \
            -map 0:v \
            -map 1:a \
            -c:v libx264 \
            -preset ultrafast \
            -pix_fmt yuv420p \
            -c:a aac \
            "${output}" \
            -hide_banner \
            -loglevel error &
    fi

    echo $(date +'%s') > ${metadata}/starttime

    dm -msg "$msg"

    if [[ -f $metadata/elapsedtime ]]; then
        screencast_rec_timer.sh $(cat $metadata/elapsedtime) &
    else
        screencast_rec_timer.sh &
    fi

    REVERSETIMER_PID=$!
    echo $REVERSETIMER_PID > $metadata/rec.pid

}


pause_recording() {
    if [[ -d "$metadata" ]] && pgrep ffmpeg > /dev/null
    then
        if [[ -f $metadata/elapsedtime ]]; then
            elapsed_time=$(( $(date +'%s') - $(< $metadata/starttime) + $(< $metadata/elapsedtime) ))
        else
            elapsed_time=$(( $(date +'%s') - $(< $metadata/starttime) ))
        fi
        echo $elapsed_time > $metadata/elapsedtime
        pkill ffmpeg
        while pgrep ffmpeg > /dev/null; do sleep 0.1; done
        [[ -f $metadata/rec.pid ]] && kill -HUP "$(cat "$metadata/rec.pid")" >/dev/null 2>&1

        dm -msg "Recording paused"

        screencast_rec_timer.sh -P $(cat $metadata/elapsedtime) &
        REVERSETIMER_PID=$!
        echo $REVERSETIMER_PID > $metadata/rec.pid

        echo paused=true >> $metadata/info
    else
        dm -msg "Nothing to pause"
        exit 1
    fi
}


resume_recording() {
    if [[ -d "$metadata" ]] && grep -q paused=true ${metadata}/info
    then
        fp=$(grep filepath ${metadata}/info | cut -d '=' -f 2)
        echo ${fp} >> ${metadata}/mergelist.txt
        filename="$(grep title= ${metadata}/info | cut -d '=' -f 2 | cut -d. -f1 | cut -d '_' -f 1)_$(date +'%s').mkv"
        grep -q 'source=' ${metadata}/info && mode=1 || mode=0
        [[ -f $metadata/rec.pid ]] && kill -HUP "$(cat "$metadata/rec.pid")" >/dev/null 2>&1
        start_recording # again
    else
        dm "Nothing to resume"
        exit 1
    fi
}


stop_recording () {
    if pgrep ffmpeg &> /dev/null
    then
        pkill ffmpeg
        while pgrep ffmpeg > /dev/null; do sleep 0.1; done
        [[ -f $metadata/rec.pid ]] && kill -HUP "$(cat "$metadata/rec.pid")" >/dev/null 2>&1
        dm "Recording stopped"
    fi

    if [ -f ${metadata}/mergelist.txt ]
    then
        fp=$(grep filepath ${metadata}/info | cut -d '=' -f 2)
        echo ${fp} >> ${metadata}/mergelist.txt
        sed -i "s|^|file '|; s|$|'|" ${metadata}/mergelist.txt
        fp="${SCREENCAST_DIR}/final_$(date +'%s').mkv"
        if ffmpeg -f concat -safe 0 -i ${metadata}/mergelist.txt \
            -c copy -movflags +faststart "${fp}" -hide_banner -loglevel error
        then
            filename=$(head -1 ${metadata}/mergelist.txt | cut -d ' ' -f 2)
            filename="${filename//[\"\']/}"
            sed 's/^file/rm/g' ${metadata}/mergelist.txt | bash
            mv ${fp} ${filename}
            echo "Recording saved to '`realpath ${filename}`'"
        else
            echo Concatnating files with ffmpeg has failed. May require manual intervention.
            exit 1
        fi
    fi

    if [ -d ${metadata} ]; then
        rm -r ${metadata}
    else
        dm "Nothing to stop"
    fi
}


show_status() {
    if [ -d ${metadata} ]
    then
        cat ${metadata}/info
        if [ -f ${metadata}/mergelist.txt ]
        then
            echo
            echo --- MERGE LIST ---
            nl ${metadata}/mergelist.txt
        fi
    else
        dm "Nothing to show"
        exit 1
    fi

}


SCREENCAST_DIR="${HOME}/Videos/screencasts"
metadata="/tmp/screencast.${USER}"

if [ ! -d "${SCREENCAST_DIR}" ]
then
    mkdir -p "${SCREENCAST_DIR}"
fi

set_action() {
    if [ -n "$action" ]; then 
         echo "Error: conflicting actions '$action' and '$1'"
         exit 1
    fi

    action="$1"
}


while [ -n "$1" ]; do
    case "$1" in
        -b|--begin)  
            set_action "begin"
            filename="${2//[\"\']/}"
            shift 2 
            ;;

        -m|--mode)   
            mode="${2//[\"\']/}";
            shift 2 
            ;;

        -s|--stop)   
            set_action "stop"
            shift 
            ;;

        -p|--pause)  
            set_action "pause"
            shift 
            ;;

        -r|--resume) 
            set_action "resume"
            shift 
            ;;

        -i|--info)
            set_action "info"
            shift 
            ;;

        -w|--watch)
            set_action "watch"
            shift 
            ;;

        -h|--help)   
            display_help
            exit 0 
            ;;

        --)
            shift 
            break
            ;;
        *)
            display_help
            exit 1 
            ;;
    esac
done

declare -A actions=(
    [begin]="start_recording"
    [stop]="stop_recording"
    [pause]="pause_recording"
    [resume]="resume_recording"
    [info]="show_status"
    [watch]="watch_recording"
)

${actions[$action]}
