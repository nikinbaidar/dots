#!/usr/bin/env bash

if ! pacman -Qu linux ; then
    exit 1
fi

/usr/bin/pacman -Syu --noconfirm >> /var/log/arch-update.log 2>&1 || exit 1

if [ $(hostnamectl hostname) = 'leviathan' ]; then
    cp -v /boot/* /efi/EFI/arch
    cp -v /efi/EFI/arch/initramfs-linux.img /efi/EFI/arch/initramfs-linux-fallback.img
    mkinitcpio -P
fi

read -p "Do you want to reboot now? [N/y] " ans

if [ ${ans} = "y" ]; then
    /usr/bin/reboot
fi

echo "To check update logs check `/var/log/arch-update.log`"
