#!/usr/bin/env python3

import pandas as pd
import pyperclip

machines = pd.read_csv('/home/nikin/manuals/_logs/machines.csv')
sn = input("Enter machine SN: ").strip().upper()
product_code = sn[:3]

try:
    info = machines.set_index("Product Code").loc[product_code].to_dict()
except KeyError as k:
    print(f"Product Code {k} not found\n")
    model = input("Enter model: ").strip()
    instrument_type = input("Enter instrument type: ").strip()
    with open('/home/nikin/manuals/_logs/machines.csv', 'a') as f:
        f.write(f"\n{product_code},{model},{instrument_type}")
    info = {
            'Model': model,
            'Instrument Type': instrument_type
            }

expected_serial_num_length = 11 if product_code[-1] == "-" else 12

if len(sn) != expected_serial_num_length:
    print(f"\n'{sn}' length is {len(sn)}. " \
          f"It may be invalid for {info['Model']} {info['Instrument Type']}.\n")

customer = input("Enter customer name: ").strip()
customer = customer.title() if " " in customer else customer.upper()
print()
description = input("Requests needing our support:\n\n")
breakdown_order = f"""
Product: {info['Instrument Type']}
Model: {info['Model']}
Serial Number: {sn}
Requests needing out support:

{description}

Machine Located Country: Nepal
Hospital name: {customer}
Distributor ID: S200560
Contact Person: Nikin (Service engineer @ GMS)
Contact: 9700047278
"""

print(breakdown_order)
pyperclip.copy(breakdown_order)
print("Breakdown order copied to system clipboard.")
