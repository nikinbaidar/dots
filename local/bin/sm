#!/bin/bash

file=`fd -I --full-path /home/nikin/manuals /home/nikin/manuals --exclude Archives | fzf`


if [ -n "${file}" ]
then
    mime=$(xdg-mime query filetype "$file")
fi

if [[ "${mime}" == text/* && "${file}" != *.html ]]; then
  /usr/bin/nvim "${file}"
elif [[ -n "${file}" ]]; then
  xdg-open "${file}" &
else
  :
fi
