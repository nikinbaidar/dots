#!/usr/bin/env bash

# Recursively renames files and directories in the current directory.
# Renaming rules:
#   - Regular files : replaces all '-' characters with '_'
#   - Directories   : replaces all '_' characters with '-'
# Keeps anything else as is.

find . -depth -mindepth 1 | while read -r f; do
  base=$(basename "$f")
  dir=$(dirname "$f")

  if [ -f "$f" ]; then
    newbase="${base//-/_}"
  elif [ -d "$f" ]; then
    newbase="${base//_/-}"
  else
    continue
  fi

  [ "$base" != "$newbase" ] && mv "$f" "$dir/$newbase"
done
