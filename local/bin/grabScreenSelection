#!/usr/bin/env bash

function openFilePickerDialog() {
    local CAPTURE=/tmp/screenshot.png
    local fnames=/tmp/fnames 
    local output
    local sub_dir
    local p="\e[00;33m"
    local w="\e[00;37m"

    echo -e "\n${p}:: Select destination file:${w}\n"

    # NOTE: Optimize the find block as much as possible.
    fd --absolute-path -i -t d -E "_site" --base-directory "$HOME" > $fnames
    fd --absolute-path -i -t f -e png -e jpg -e jpeg -e webp -e gif \
        -e bmp -e tif -e tiff -e avif -e heic -e heif \
        -E "_site" --base-directory "$HOME" >> $fnames

    output=$(fzf < $fnames)
    echo $output
    rm -f $fnames

    if [[ -z "$output" ]]; then
        rm "$CAPTURE"
        return 1
    fi

    if [[ -d "$output" ]]; then
        echo -en "${p}:: Enter new filename: ${w}${output}" 
        read -r filename
        echo
        output="${output%/}/${filename}"
        sub_dir=$(dirname "$output")
        [[ ! -d $sub_dir ]] && mkdir -p "$sub_dir"
    fi


    if mv -i "$CAPTURE" "$output"; then
         printf '![%s](%s)' "$(basename "${output%.*}")" "$output" \
             | setsid -f xclip -selection primary >/dev/null 2>&1
    fi

}

CAPTURE=/tmp/screenshot.png

slop_args=(-n -c 0.5,0.5,0.5,0.7)
[[ -x /usr/bin/picom ]] && slop_args+=(-l --bordersize=0)

shotgun --geometry "$(slop "${slop_args[@]}")" - | satty -f -

if [ -f $CAPTURE ]; then
    export -f openFilePickerDialog
    st -c "Lehte" -T "Lehte - Terminal File Picker"\
        -g 95x27 sh -c 'openFilePickerDialog'
fi
