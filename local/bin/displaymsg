#!/usr/bin/env bash

DisplayMessage() {
    local padstr=$(printf '%*s' "1" '')

    echo
    while IFS= read -r line; do
        echo "${padstr}${line}"
    done <<< "$DISPLAY_MSG"
    tput civis
    read -rn 1 -t 5
}

readonly COLS=30

DISPLAY_MSG=$(fold -s -w $COLS <<< "$1")
ROWS=$(( $(wc -l <<< "$DISPLAY_MSG") + 2 ))

export -f DisplayMessage
export DISPLAY_MSG

st -c "Display message" -T "Display message" -z 20 \
    -g ${COLS}x${ROWS} bash -c 'DisplayMessage "$DISPLAY_MSG"'
