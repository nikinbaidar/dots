function notes() {
    local PORT=5900
    local NOTES_DIR=~/notes

    case $1 in
        -s|--sync)
            pushd "$NOTES_DIR"
            local branch
            branch=$(git symbolic-ref --short HEAD)
            git pull
            if [[ -n "$(git status -s)" ]]
            then
                git add --all
                git commit -m "o.O"
                git push -U origin "$branch" --verbose
            else
                echo "Nothing to push."
            fi
            popd > /dev/null
            ;;
        -p|--preview)
            pushd "$NOTES_DIR"
            if fuser "$PORT/tcp" > /dev/null 2>&1 ; then
                fuser -k -9 "$PORT/tcp" > /dev/null 2>&1
                quarto preview --port ${PORT} --no-browser
            else
                quarto preview --port ${PORT}
            fi
            popd > /dev/null
            ;;
        -h|--help)
            echo "Usage: notes [-s | --sync] [-p | --preview] [-h | --help]"
            ;;
        *)
            cd "$NOTES_DIR"
    esac
}
