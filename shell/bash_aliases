function hb() {
    # Handle block devices
    local mntpt selection
    mntpt="/run/media/$USER"

    selection="$(ls -1 --color=never $mntpt | fzf)" || return 1
    selection="${mntpt}/${selection}"

    if [ "$1" = "-u" ]; then
        local device
        device=$(findmnt -n -o SOURCE "$selection")
        udiskie-umount $device || return 1
        return 0
    fi

    if [ -d "$selection" ]; then
        cd "$selection"
    fi

    return 0
}


